# 复制为 .env 后按需修改
APP_ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false

# 与 docker-compose.yml 对应
DATABASE_URL=postgresql+asyncpg://agentgate:agentgate@localhost:5432/agentgate
REDIS_URL=redis://localhost:6379/0

# Provider：二选一。
# Anthropic 原生（v1/messages, x-api-key）：
ANTHROPIC_API_KEY=
# OpenAI 兼容端点（chat/completions, Bearer），如 DeepSeek 代理：
OPENAI_BASE_URL=
OPENAI_API_KEY=

# 默认模型（对话主模型）
DEFAULT_MODEL=claude-opus-4-8
# 全量摘要压缩用的低成本模型（阶段 3）。留空则复用 DEFAULT_MODEL。
SUMMARY_MODEL=
